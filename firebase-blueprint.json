{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead from the website form.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the lead." },
        "email": { "type": "string", "format": "email", "description": "Email address of the lead." },
        "phone": { "type": "string", "description": "Phone number of the lead." },
        "city": { "type": "string", "description": "City of the lead." },
        "service": { "type": "string", "description": "Type of service requested." },
        "details": { "type": "string", "description": "Details about the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the lead was created." }
      },
      "required": ["fullName", "email", "phone", "city", "service", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": { "$ref": "Lead" },
      "description": "Collection of customer leads."
    }
  }
}
